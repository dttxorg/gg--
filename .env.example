# ===== Auth.js =====
# 生成: openssl rand -base64 32
AUTH_SECRET=替换为你的密钥
AUTH_TRUST_HOST=true

# ===== Database (Vercel Postgres / Neon) =====
# Vercel Postgres 默认注入的变量名是 POSTGRES_URL / POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING
# Prisma 习惯读 DATABASE_URL，所以手动设一个指向同一个值
# 在 Vercel Environment Variables 加：
#   DATABASE_URL = <与 POSTGRES_PRISMA_URL 相同的值（带 ?sslmode=require&pgbouncer=true&connect_timeout=15）>
# 或者直接用 Neon 的 Connection String
DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=require

# ===== Cloudflare R2 图片存储 =====
R2_ACCOUNT_ID=你的R2账户ID
R2_ACCESS_KEY_ID=你的R2访问Key
R2_SECRET_ACCESS_KEY=你的R2密钥
R2_BUCKET=giffgaff-agent-hub
# R2 公开访问域名（在 R2 控制台 → 你的 bucket → Settings → Public development URL）
R2_PUBLIC_HOST=https://pub-你的id.r2.dev
